# Telegram — токен от @BotFather (никогда не коммитьте реальные значения)
BOT_TOKEN=your_bot_token_here

# SOCKS для Telegram выключен по умолчанию (прямой доступ к api.telegram.org).
# Локальный прокси (папка /proxy): TELEGRAM_SOCKS_PROXY_ENABLED=1
# Удалённый SOCKS5 (если хост блокирует Telegram): см. docs/TELEGRAM_SOCKS_PROXY.md
# TELEGRAM_SOCKS_PROXY_ENABLED=1
# TELEGRAM_SOCKS_PROXY_URLS=socks5h://user:pass@host:443
# Только локально (прокси на ПК :1080), не в Docker без явного URL:
# TELEGRAM_SOCKS_PROXY_DEFAULT_LOCAL=1
# Редко: разрешить 127.0.0.1 в URL (sidecar); в обычном Docker на VPS не нужно:
# TELEGRAM_SOCKS_ALLOW_LOOPBACK=1
# В Docker без прокси в контейнере ничего не задавайте (или TELEGRAM_SOCKS_PROXY_ENABLED=0).
# TELEGRAM_DROP_PENDING_UPDATES=1   # при старте сбросить накопившиеся апдейты (опционально)

# Database (SQLite path or PostgreSQL URL)
DATABASE_URL=file:./data/bot.sqlite
# DATABASE_URL=postgresql://user:pass@localhost:5432/bot_kicker

# Encryption key for credentials in DB (32 bytes hex or base64)
ENCRYPTION_KEY=your-32-byte-hex-key-here

# Google APIs: положите Service Account JSON в secrets/ (файл не в git)
GOOGLE_APPLICATION_CREDENTIALS=./secrets/calendar-service-account.json

# Planner: Google Sheets и `/planner_week` — см. docs/PLANNER.md
# PLANNER_SHEET_ID=   # ID таблицы из URL (обязательно для выгрузки в 21:00)
# Если в имени листа или в A1 есть «!», для docker compose оберните значение в двойные кавычки:
# PLANNER_SHEET_RANGE="'Мой лист'!A:O"
# PLANNER_SHEET_RANGE=Sheet1!A:D   # без пробелов/спецсимволов — можно без кавычек
# Attendance debts source (read-only tab)
# ATTENDANCE_SHEET_ID=   # если не задан, используется PLANNER_SHEET_ID
# ATTENDANCE_SHEET_TAB=Посещаемость

# Optional: timezone for event windows (e.g. Europe/Moscow)
TZ=Europe/Moscow

# Optional: enable debug logs
DEBUG=1
